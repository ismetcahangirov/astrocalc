# Backend API base URL (the Express server from apps/backend).
API_BASE_URL=http://localhost:4000

# Google OAuth client IDs from https://console.cloud.google.com/apis/credentials
# The WEB client id is used for the backend `aud` check and by the Android /
# expo-auth-session flows; the IOS client id is used by the native iOS SDK.
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# The iOS URL scheme is the iOS client id reversed, e.g.
# com.googleusercontent.apps.your-ios-client-id
GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.your-ios-client-id
