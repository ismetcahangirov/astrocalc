# --- Server ---
PORT=4000
NODE_ENV=development

# --- Database (Neon serverless Postgres) ---
# Connection string from the Neon dashboard.
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# --- Google OAuth ---
# Comma-separated list of accepted Google OAuth client IDs (the `aud` claim of
# the ID token must match one of these). Include every platform's client ID:
#   - Web client ID (used by the backend / expo-auth-session fallback)
#   - iOS client ID
#   - Android client ID
# See https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com,your-ios-client-id.apps.googleusercontent.com

# --- JWT ---
# Use long, random, distinct secrets in production (e.g. `openssl rand -hex 32`).
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
# Access token lifetime (short-lived). Accepts vercel/ms-style strings.
JWT_ACCESS_TTL=15m
# Refresh token lifetime (long-lived).
JWT_REFRESH_TTL=30d
